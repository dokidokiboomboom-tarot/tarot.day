        function getRandomCards(count) {
            let deck = [...tarotDeck];
            for (let i = deck.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [deck[i], deck[j]] = [deck[j], deck[i]];
            }
            return deck.slice(0, count).map(card => ({...card, isReversed: Math.random() > 0.5}));
        }

