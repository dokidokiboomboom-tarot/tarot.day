                const dispAdv = ai?.cardReadings?.[idx]?.advice || data.advice;

                if (visual) visual.innerHTML += `<div class="text-center w-32 md:w-40"><p class="text-xs text-pink-400 mb-1 font-bold">${pos[idx]}</p><div class="w-full pt-[170%] relative rounded-lg overflow-hidden shadow-lg border border-pink-500/30"><div class="absolute inset-0">${getCardImageHTML(card.imgFileName, card.isReversed)}</div></div><p class="text-xs text-gray-200 mt-2 font-serif">${card.name} <br> ${card.isReversed?'(逆位)':'(正位)'}</p></div>`;
                detailedHTML += `<div class="bg-gray-800/40 rounded-2xl p-6 md:p-10 border border-gray-700 mb-10 shadow-xl"><div class="flex items-center gap-4 mb-8 border-b border-gray-700/50 pb-5"><div class="w-10 h-10 rounded-full bg-pink-500 text-black flex items-center justify-center font-bold text-lg">${idx+1}</div><h3 class="text-2xl serif text-white">【${pos[idx]}】 ${card.name}</h3></div><div class="space-y-8"><div><h4 class="text-sm font-bold text-pink-400 mb-3 flex items-center gap-2"><i class="fa-solid fa-book-open"></i> 偉特牌核心精神：</h4><p class="text-gray-200 text-base leading-relaxed">${dispM}</p></div><div><h4 class="text-sm font-bold text-pink-400 mb-3 flex items-center gap-2"><i class="fa-solid fa-comments"></i> 針對問題的深度解析：</h4><p class="text-gray-200 text-base leading-relaxed">${dispA}</p></div><div class="bg-pink-900/10 p-5 rounded-xl border-l-4 border-pink-500"><h4 class="text-sm font-bold text-pink-400 mb-2 flex items-center gap-2"><i class="fa-solid fa-wand-magic-sparkles"></i> 導師的小建議：</h4><p class="text-gray-100 text-sm md:text-base italic">${dispAdv}</p></div></div></div>`;
            });

            // 如果沒有 AI，則使用防廢話機制的動態統整
            let tone = "";
            if (ai && ai.overallTone) {
                tone = ai.overallTone;
            } else {
                const revCount = cards.filter(c => c.isReversed).length;
                const trend = revCount >= cards.length / 2 
                    ? "從牌陣整體的能量流動來看，逆位能量較多，這強烈暗示著目前的局勢在水面下遇到了一些內在的阻力或是外在的延遲。宇宙正在溫柔地提醒你，這是一個需要放慢腳步的時刻，重新檢視你的初衷與執行方法，強求反而會適得其反。" 
                    : "綜合牌陣整體的流向，顯示出強大且正向的動能。你目前的方向與頻率是正確的，雖然過程中難免會有挑戰，但只要保持初心與專注，宇宙的能量會在你背後推動你前進，局勢的發展是令人期待的。";
                tone = `針對你所詢問的「${state.question}」，${trend} 請綜合上述每一張牌所提供的深層指引來思考。塔羅並非給予絕對的判決，而是如同一面鏡子，反映出你當下與未來的潛意識狀態。藉由調整當下的頻率，你絕對有能力顯化出更好的未來。`;
            }

            const core = ai?.finalAdvice || "保持內心的平靜，順應局勢的發展。";
            const acts = ai?.dailyActions || ["寫下目前的感受","練習深呼吸","喝杯熱水放鬆"];

            detailedHTML += `
                <div class="bg-gradient-to-b from-gray-900 to-black rounded-3xl p-8 md:p-14 border border-pink-500/40 shadow-2xl mt-16">
                    <h3 class="text-3xl md:text-4xl serif gold-text text-center mb-12 pb-6 border-b border-gray-800">✨ 能量整合與總結建議 ✨</h3>
                    <div class="space-y-12">
                        <div>
                            <h4 class="font-bold text-white mb-4 text-xl flex items-center gap-3"><i class="fa-solid fa-yin-yang text-pink-400"></i> 整體趨勢與因果統整</h4>
                            <p class="text-gray-200 text-lg leading-relaxed">${tone}</p>
                        </div>
                        <div class="bg-pink-500/10 p-8 rounded-2xl border border-pink-500/20 text-center">
                            <h4 class="font-bold text-pink-400 mb-4 text-xl">🎯 靈魂核心導航</h4>
                            <p class="text-gray-100 text-xl md:text-2xl font-serif italic">「${core}」</p>
                        </div>
                        <div>
                            <h4 class="font-bold text-white mb-6 text-xl flex items-center gap-3"><i class="fa-solid fa-person-walking-arrow-right text-pink-400"></i> 身心靈落實行動建議</h4>
                            <div class="grid gap-6 md:grid-cols-3">
                                ${acts.map(a => `<div class="action-card flex items-center text-center"><p class="text-gray-200 w-full text-base font-medium">${a}</p></div>`).join('')}
                            </div>
                        </div>
                        <div class="mt-12 pt-10 border-t border-pink-500/20 text-center">
                            <h4 class="font-bold text-pink-300 mb-6 italic tracking-widest text-lg">✨ 大天使的神諭祝福 ✨</h4>
                            <div class="archangel-box p-8 md:p-12 rounded-3xl">
                                <p class="text-yellow-400 font-bold text-xl md:text-2xl leading-relaxed italic font-serif">
                                    "${archangelMessages[Math.floor(Math.random()*archangelMessages.length)]}"
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mt-16 bg-gray-900 p-10 rounded-2xl text-center relative hover:border-pink-500/40 transition">
                    <h4 class="text-2xl serif gold-text mb-4">想聊得更深嗎？</h4>
                    <p class="text-gray-400 text-base mb-8">有些話語需要透過更深層的互動來傳遞，歡迎預約深度諮詢。</p>
                    <a href="https://www.instagram.com/dokidokiboomboom.tarot/" target="_blank" class="inline-block btn-outline-gold px-10 py-4 rounded-full text-base font-bold"><i class="fa-brands fa-instagram mr-2"></i> 聯絡占卜師 (預約深度占卜)</a>
                </div>`;
            
            if (content) content.innerHTML = detailedHTML;
            const resTitle = document.getElementById('res-title');
            if (resTitle) setTimeout(() => resTitle.scrollIntoView({ behavior: 'smooth' }), 100);
            
            // 儲存紀錄
            state.currentResult = { id: Date.now().toString(), date: new Date().toLocaleString(), mode, question: state.question, cards, positions: pos, aiReading: ai, isFavorite: false };
            saveToStorage(state.currentResult);
            document.getElementById('fav-icon').className = "fa-regular fa-star text-3xl";
        }

        function backToSetup() { 
            const resArea = document.getElementById('result-area');
            if (resArea) resArea.classList.add('hidden'); 
            
            const loadingArea = document.getElementById('loading-area');
            if (loadingArea) {
                loadingArea.classList.add('hidden');
                loadingArea.classList.remove('flex');
            }
            
            state.selectedCards = [];
            
            if(state.currentDrawMode === 'daily') {
                switchTab('daily');
                const dailyAnim = document.getElementById('daily-card-anim');
                if (dailyAnim) dailyAnim.classList.remove('flipped');
            } else {
                switchTab('reading');
                const readingSetup = document.getElementById('reading-setup');
                const manualDrawArea = document.getElementById('manual-draw-area');
                const btnReveal = document.getElementById('btn-reveal');
                if (readingSetup) readingSetup.classList.remove('hidden');
                if (manualDrawArea) manualDrawArea.classList.add('hidden');
                if (btnReveal) btnReveal.classList.add('hidden');
                
                setTimeout(() => {
                    const setupTitle = document.querySelector('#reading-setup h2');
                    if (setupTitle) setupTitle.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 50);
            }
        }

        function getHistory() { try { return JSON.parse(localStorage.getItem('tarotHistory') || '[]'); } catch (e) { return []; } }
        function setHistory(h) { localStorage.setItem('tarotHistory', JSON.stringify(h)); }
        function saveToStorage(r) { let h = getHistory(); if (!h.some(x => x.id === r.id)) { h.unshift(r); if(h.length > 200) h = h.slice(0, 200); setHistory(h); } }
        function toggleFavoriteCurrent() { const icon = document.getElementById('fav-icon'); let h = getHistory(), idx = h.findIndex(x => x.id === state.currentResult.id); if(idx !== -1) { h[idx].isFavorite = !h[idx].isFavorite; state.currentResult.isFavorite = h[idx].isFavorite; icon.className = h[idx].isFavorite ? "fa-solid fa-star text-yellow-500 text-3xl" : "fa-regular fa-star text-3xl"; setHistory(h); } }
        function renderHistory(f = 'all', btn = null) {
            const container = document.getElementById('history-list');
            if(btn) { document.querySelectorAll('.filter-btn').forEach(b => { b.classList.remove('text-pink-400', 'underline', 'font-bold'); b.classList.add('text-gray-400'); }); btn.classList.add('text-pink-400', 'underline', 'font-bold'); }
            let h = getHistory(); if(f === 'favorites') h = h.filter(x => x.isFavorite);
            if(h.length === 0) return container.innerHTML = `<p class="text-gray-500 text-center py-20">目前還沒有紀錄喔。</p>`;
            container.innerHTML = h.map(x => `
                <div class="glass-panel p-5 rounded-2xl flex items-center justify-between border border-gray-700 hover:border-pink-500/50 transition">
                    <div class="flex-1 cursor-pointer" onclick="viewHistory('${x.id}')">
                        <div class="flex items-center gap-2 mb-2 text-xs">
                            <span class="bg-gray-800 px-2 py-0.5 rounded text-gray-400">${x.mode==='daily'?'每日一抽':x.cards.length+'張'}</span>
                            <span class="text-gray-500">${x.date}</span>
                        </div>
                        <h4 class="text-white font-medium truncate max-w-md">${x.question}</h4>
                    </div>
                    <div class="flex gap-5 ml-5">
                        <button onclick="toggleFavoriteList('${x.id}')"><i class="${x.isFavorite?'fa-solid text-yellow-500':'fa-regular text-gray-500'} fa-star text-xl"></i></button>
                        <button onclick="deleteHistory('${x.id}')" class="text-gray-500 hover:text-red-500"><i class="fa-solid fa-trash-can"></i></button>
                    </div>
                </div>
            `).join('');
        }
        function toggleFavoriteList(id) { let h = getHistory(), idx = h.findIndex(x => x.id === id); if(idx !== -1) { h[idx].isFavorite = !h[idx].isFavorite; setHistory(h); renderHistory(); } }
        function deleteHistory(id) { if(!confirm("確定要刪除這筆回憶嗎？")) return; setHistory(getHistory().filter(x => x.id !== id)); renderHistory(); }
        function viewHistory(id) {
            const r = getHistory().find(x => x.id === id);
            if(r) {
                state.question = r.question; state.currentDrawMode = r.mode; state.currentResult = r;
                showResults(r.cards, r.mode, r.positions, r.aiReading);
                document.getElementById('fav-icon').className = r.isFavorite ? "fa-solid fa-star text-yellow-500 text-3xl" : "fa-regular fa-star text-3xl";
            }
        }

        function openModal(id) {
            const textEl = document.getElementById('universe-message-text');
            if(id==='modal-cta' && textEl) textEl.innerHTML = universeMessages[Math.floor(Math.random()*universeMessages.length)];
            const m = document.getElementById(id), c = document.getElementById(id + '-content');
            if (m) { m.classList.remove('hidden'); m.classList.add('flex'); }
            if (c) setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeModal(id) {
            const m = document.getElementById(id), c = document.getElementById(id + '-content');
            if (c) c.classList.add('scale-95', 'opacity-0');
            if (m) setTimeout(() => { m.classList.add('hidden'); m.classList.remove('flex'); }, 300);
        }
    </script>
</body>
</html>
