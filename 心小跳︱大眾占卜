        function setupManualDeck() {
            const deck = document.getElementById('deck-container'), slots = document.getElementById('selected-slots');
            deck.innerHTML = ''; slots.innerHTML = ''; document.getElementById('btn-reveal').classList.add('hidden');
            state.selectedCards = [];
            
            // 預先洗好 78 張牌，確保抽牌不會重複，且完全模擬真實桌面的物理狀態
            state.currentDeck = getRandomCards(78);
            
            for(let i=0; i<state.spread; i++) slots.innerHTML += `<div class="w-16 h-24 md:w-20 md:h-28 border-2 border-dashed border-gray-600 rounded-lg flex items-center justify-center text-gray-500" id="slot-${i}">${i+1}</div>`;
            
            // 攤開 78 張牌 (變成更大的完美扇形)
            for(let i=0; i<78; i++) {
                let angle = -75 + (i * (150 / 77)); // 將卡牌均勻分佈在 -75度 到 75度 的更廣扇形區間
                deck.innerHTML += `<div class="fan-card card-back border border-gray-700/50 rounded-md" style="--rot: ${angle}deg; --idx: ${i};" data-card-index="${i}" onclick="pickManualCard(this)"></div>`;
            }
        }
        
        function pickManualCard(el) {
            if(state.selectedCards.length >= state.spread || el.classList.contains('opacity-0')) return;
            
            // 讓被抽走的牌消失，留下空位，營造從桌面上抽走牌的真實感
            el.classList.add('opacity-0', 'pointer-events-none');
            
            // 根據他點擊的特定位置，取出對應的卡牌
            const cardIndex = parseInt(el.getAttribute('data-card-index'));
            const pickedCard = state.currentDeck[cardIndex];
            state.selectedCards.push(pickedCard);
            
            const slot = document.getElementById(`slot-${state.selectedCards.length - 1}`);
            // 直接顯示牌面，並加上發光特效
            slot.innerHTML = `
                <div class="w-full h-full rounded-lg overflow-hidden border border-yellow-600 shadow-[0_0_15px_rgba(251,113,133,0.5)] flex items-center justify-center bg-[#fdfbf7] animate-pulse">
                    ${getCardImageHTML(pickedCard.imgFileName, pickedCard.isReversed)}
                </div>
            `;
            slot.classList.remove('border-dashed', 'border-gray-600');
            if(state.selectedCards.length === state.spread) document.getElementById('btn-reveal').classList.remove('hidden');
        }
        
