                        <div>
                            <h4 class="font-bold text-white mb-2"><i class="fa-solid fa-chart-pie text-yellow-600 mr-2"></i>牌面整體感受</h4>
                            <p class="text-gray-200 text-sm md:text-base leading-relaxed">${cards.length > 1 ? overallTone + '<br><br>' : ''} 針對你這次的問題，最核心的總結就是：「<strong>${finalCoreAdvice}</strong>」</p>
                        </div>

                        ${mode === 'daily' ? `
                        <div class="bg-white/5 p-5 rounded-lg border border-gray-700 shadow-inner">
                            <h4 class="font-bold text-yellow-400 mb-3"><i class="fa-solid fa-person-running mr-2"></i>今天你可以試著這樣做：</h4>
                            <ul class="text-gray-200 text-sm list-disc list-inside space-y-2">
                                ${actionsList.map(act => `<li>${act}</li>`).join('')}
                            </ul>
                        </div>
                        ` : ''}

                        <div class="mt-8 pt-6 border-t border-yellow-600/20">
                            <h4 class="font-bold text-white mb-4 text-center">✨ 抽一張大天使的神諭祝福 ✨</h4>
                            <div class="bg-black/40 p-6 md:p-8 rounded-lg text-center shadow-lg border border-yellow-600/30">
                                <p class="text-yellow-400 font-bold text-lg md:text-xl leading-relaxed tracking-wide italic">
                                    "${randomOracle}"
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 預約占卜 CTA -->
                <div class="mt-10 bg-gray-900 p-8 rounded-xl border border-gray-800 text-center relative overflow-hidden group hover:border-yellow-600/50 transition duration-500">
                    <div class="absolute -right-5 -top-5 text-8xl text-white/5 group-hover:text-yellow-500/10 transition duration-500"><i class="fa-solid fa-star"></i></div>
                    <h4 class="text-xl md:text-2xl serif gold-text mb-3">覺得還意猶未盡，想聊得更深嗎？</h4>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed max-w-2xl mx-auto">
                        線上的文字雖然能給你一個大方向的指引，但如果你的狀況比較複雜，或者心裡真的覺得很難受，非常歡迎你來找我預約一對一的深度占卜。<br>我們一起把牌攤開，好好聊聊。
                    </p>
                    <a href="https://www.instagram.com/milktea3517/" target="_blank" rel="noopener noreferrer" class="inline-block btn-outline-gold px-8 py-3 rounded-full text-sm font-bold tracking-wider hover:bg-yellow-600 hover:text-black shadow-lg">
                        <i class="fa-brands fa-instagram mr-2"></i> 聯絡占卜師 (預約諮詢)
                    </a>
                </div>
            `;

            contentContainer.innerHTML = detailedHTML;

            // 儲存紀錄 (將 AI 解讀結果一起存入歷史，下次讀取歷史時就不必重新等待 AI)
            state.currentResult = { 
                id: Date.now().toString(), 
                date: new Date().toLocaleString(), 
                mode: mode, 
                question: state.question, 
                cards: cards, 
                positions: positions,
                aiReading: aiReading,
                isFavorite: false 
            };
            saveToStorage(state.currentResult);
            
            setTimeout(() => {
                document.getElementById('res-title').scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }

        function backToSetup() {
            document.getElementById('result-area').classList.add('hidden');
            if(state.currentDrawMode === 'daily') document.getElementById('daily-setup').classList.remove('hidden');
            else document.getElementById('reading-setup').classList.remove('hidden');
        }

        // -----------------------
        // 6. 歷史與收藏邏輯 (所有紀錄永久保留)
        // -----------------------
        let inMemoryHistory = []; 

        function getHistory() { 
            try {
                return JSON.parse(localStorage.getItem('tarotHistory') || '[]'); 
            } catch (e) {
                return inMemoryHistory;
            }
        }

        function setHistory(history) {
            try {
                localStorage.setItem('tarotHistory', JSON.stringify(history));
            } catch (e) {
                inMemoryHistory = history;
            }
        }

        function saveToStorage(record) {
            let history = getHistory();
            // 避免重複存入同樣的 ID
            if (!history.some(h => h.id === record.id)) {
                history.unshift(record);
                // 總紀錄筆數上限拉高到 200 筆，避免空間爆掉
                if(history.length > 200) history = history.slice(0, 200);
                setHistory(history);
            }
        }

        function toggleFavoriteCurrent() {
            const icon = document.getElementById('fav-icon');
            let history = getHistory();
            let index = history.findIndex(h => h.id === state.currentResult.id);
            if(index !== -1) {
                history[index].isFavorite = !history[index].isFavorite;
                state.currentResult.isFavorite = history[index].isFavorite;
                icon.className = history[index].isFavorite ? "fa-solid fa-star text-yellow-500 text-xl" : "fa-regular fa-star text-xl";
                setHistory(history);
            }
        }

        function renderHistory(filter = 'all') {
            const container = document.getElementById('history-list');
            let history = getHistory();
            if(filter === 'favorites') history = history.filter(h => h.isFavorite);

            if(history.length === 0) return container.innerHTML = `<p class="text-gray-500 text-center py-10">尚無${filter === 'favorites' ? '收藏' : '歷史'}紀錄。</p>`;

            container.innerHTML = history.map(h => `
                <div class="glass-panel p-4 rounded-lg flex items-center justify-between border border-gray-700 hover:border-yellow-600/50 transition">
                    <div class="flex-1 cursor-pointer hist-item" data-id="${h.id}">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-xs bg-gray-800 px-2 py-1 rounded text-gray-400">${h.mode === 'daily' ? '每日' : h.cards.length + '張牌'}</span>
                            <span class="text-xs text-gray-500">${h.date}</span>
                        </div>
                        <h4 class="text-white font-medium truncate max-w-xs">${h.question}</h4>
                        <p class="text-xs text-yellow-600 mt-1">${h.cards.map(c => c.name.split(' ')[0] + (c.isReversed ? '(逆)' : '')).join(', ')}</p>
                    </div>
                    <div class="flex gap-4 ml-4">
                        <button class="fav-hist text-xl ${h.isFavorite ? 'text-yellow-500' : 'text-gray-600 hover:text-yellow-500'}" data-id="${h.id}"><i class="${h.isFavorite ? 'fa-solid' : 'fa-regular'} fa-star"></i></button>
                        <button class="delete-hist text-gray-600 hover:text-red-500 transition" data-id="${h.id}"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
            `).join('');
        }

        function toggleFavoriteList(id) {
            let history = getHistory(), index = history.findIndex(h => h.id === id);
            if(index !== -1) {
                history[index].isFavorite = !history[index].isFavorite;
                setHistory(history);
                renderHistory(document.querySelector('.filter-btn.text-yellow-500').innerText.includes('收藏') ? 'favorites' : 'all');
            }
        }

        function deleteHistory(id) {
            if(!confirm("確定要刪除這筆紀錄嗎？")) return;
            let history = getHistory().filter(h => h.id !== id);
            setHistory(history);
            renderHistory(document.querySelector('.filter-btn.text-yellow-500').innerText.includes('收藏') ? 'favorites' : 'all');
        }

        function viewHistory(id) {
            const record = getHistory().find(h => h.id === id);
            if(record) {
                state.question = record.question; state.currentDrawMode = record.mode; state.currentResult = record;
                
                // 相容舊的歷史紀錄，若沒有存入 positions 則產生預設值
                const positions = record.positions || (record.cards.length === 3 ? ['過去的原因', '現在的狀況', '未來的建議'] : 
                              (record.cards.length === 6 ? ['過去', '現在', '未來', '你的阻礙', '你的助力', '最終建議'] : ['核心重點']));

                showResults(record.cards, record.mode, positions, record.aiReading);
                document.getElementById('fav-icon').className = record.isFavorite ? "fa-solid fa-star text-yellow-500 text-xl" : "fa-regular fa-star text-xl";
            }
        }
    </script>
</body>
</html>
