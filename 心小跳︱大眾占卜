    <script>
        const apiKey = "AIzaSyD0ZpZAmh2_N0kD0NFjj6VsamEE3xDuQB8"; 

        // 啟動流程
        function startApp() {
            document.getElementById('magical-intro').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('magical-intro').style.display = 'none';
                document.getElementById('tarot-app-container').classList.add('app-visible');
                document.body.style.overflow = 'auto';
                selectCategory('love', document.querySelector('.category-btn'));
            }, 1000);
        }

        // --- 核心：AI 解析引擎 (深度五大層次，防廢話機制) ---
        async function fetchAIReading(question, cards, positions, mode) {
            if (!apiKey) return null;
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            let ctx = cards.map((c, i) => `【${positions[i]}】: ${c.name} (${c.isReversed ? '逆位' : '正位'})`).join('\n');
            
