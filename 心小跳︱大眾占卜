                    overallTone: { type: "STRING", description: "牌面整體感受：總結這些牌與問題的關聯，給出一個大方向的宣判或安撫。" },
                    finalAdvice: { type: "STRING", description: "最核心的總結建議（一句話）" },
                    dailyActions: {
                        type: "ARRAY",
                        items: { type: "STRING" },
                        description: "3個具體的行動建議"
                    }
                },
                required: ["cardReadings", "overallTone", "finalAdvice", "dailyActions"]
            };

            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: schema
                }
            };

            try {
                let result = await fetchWithRetry(url, payload);
                let jsonText = result.candidates[0].content.parts[0].text;
                jsonText = jsonText.replace(/```json/gi, '').replace(/```/g, '').trim();
                return JSON.parse(jsonText);
            } catch (e) {
                console.error("AI 讀取失敗，將退回預設文字解讀", e);
                return null; 
            }
        }

