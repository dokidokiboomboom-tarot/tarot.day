<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>心小跳塔羅 | 靈魂的啟程</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        yellow: { 400: '#fda4af', 500: '#fb7185', 600: '#f43f5e', 800: '#be123c', 900: '#881337' },
                        gray: { 600: '#4d365e', 700: '#3f2b4f', 800: '#2d1f38', 900: '#1e1525' }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600;900&family=Noto+Sans+TC:wght@300;400;500;700&display=swap');

        :root {
            --gold: #fb7185;
            --sw-yellow: #FFE81F;
            --dark-bg: #1e1525;
            --dark-surface: #2d1f38;
        }

        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: #000;
            color: #e2e8f0;
            margin: 0;
            overflow: hidden;
        }

        /* --- 3D靈魂穿梭開場動畫 --- */
        #magical-intro {
            position: fixed; inset: 0; background: var(--dark-bg); z-index: 1000;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            overflow: hidden; perspective: 1000px; padding: 1rem;
        }

        .moving-stars {
            position: absolute; inset: -50%; background: transparent url('https://www.transparenttextures.com/patterns/stardust.png') repeat;
            animation: warpSpeed 60s linear infinite; opacity: 0.5; z-index: 0;
        }
        @keyframes warpSpeed { from { transform: rotate(0deg) scale(1); background-position: 0 0; } to { transform: rotate(5deg) scale(1.2); background-position: -5000px 5000px; } }

        .flying-cards-container { position: absolute; inset: 0; perspective: 800px; z-index: 1; pointer-events: none; }
        .flying-card {
            position: absolute; top: 50%; left: 50%;
            width: clamp(60px, 15vh, 120px); height: clamp(100px, 25vh, 190px);
            margin-top: clamp(-50px, -12.5vh, -95px); margin-left: clamp(-30px, -7.5vh, -60px);
            opacity: 0; border-radius: 6px; border: 2px solid rgba(251, 113, 133, 0.3);
            box-shadow: 0 0 30px rgba(251, 113, 133, 0.2);
            background: linear-gradient(135deg, #2d1f38 0%, #1e1525 100%);
            background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(251, 113, 133, 0.05) 10px, rgba(251, 113, 133, 0.05) 20px);
        }
        .fc-1 { animation: flyCard 5s infinite; }
        .fc-2 { animation: flyCard 7s infinite; animation-delay: 2.5s; }
        @keyframes flyCard {
            0% { transform: translate3d(calc(var(--x) * 1px), calc(var(--y) * 1px), -1000px) rotate(var(--r1)); opacity: 0; }
            30% { opacity: 0.6; } 100% { transform: translate3d(calc(var(--x) * 3px), calc(var(--y) * 3px), 600px) rotate(var(--r2)); opacity: 0; }
        }

        .intro-heart-container { position: relative; z-index: 10; margin-bottom: clamp(0.5rem, 3vh, 2rem); }
        .intro-heart { font-size: clamp(2.5rem, 10vh, 5rem); color: var(--gold); filter: drop-shadow(0 0 20px rgba(251, 113, 133, 0.8)); animation: heartbeat 1.5s infinite ease-in-out; }
        .shockwave { position: absolute; top: 50%; left: 50%; width: 10px; height: 10px; transform: translate(-50%, -50%); border-radius: 50%; border: 3px solid var(--gold); animation: shockwaveAnim 1.5s infinite ease-out; }
        @keyframes shockwaveAnim { 0% { transform: translate(-50%, -50%) scale(1); opacity: 1; } 100% { transform: translate(-50%, -50%) scale(25); opacity: 0; } }

        .intro-text-container { perspective: 800px; position: relative; z-index: 10; }
        .intro-line {
            opacity: 0; transform: rotateX(30deg) translateZ(-150px) translateY(40px);
            font-size: clamp(0.9rem, 2.5vh, 1.5rem); color: #e2e8f0; margin-bottom: clamp(0.5rem, 2vh, 1.5rem); letter-spacing: 0.1em;
            animation: dramaticFadeIn 3.5s forwards;
        }
        .line-1 { animation-delay: 0.5s; } .line-2 { animation-delay: 2.5s; } .line-3 { animation-delay: 4.5s; color: var(--gold); font-weight: bold; }
        .intro-logo-new {
            opacity: 0; font-family: 'Noto Serif TC', serif; font-weight: 900;
            font-size: clamp(2.5rem, 8vh, 5rem); color: var(--gold); text-shadow: 0 0 25px rgba(251, 113, 133, 0.8);
            margin: clamp(1rem, 4vh, 2.5rem) 0; transform: scale(0.5) translateZ(-200px);
            animation: logoSmash 3s forwards; animation-delay: 6.5s;
        }
        .intro-btn-wrap { opacity: 0; animation: dramaticFadeIn 2s forwards; animation-delay: 8s; margin-top: clamp(0.5rem, 2vh, 1.5rem); position: relative; z-index: 10; }
        @keyframes heartbeat { 0%, 100% { transform: scale(1); } 15% { transform: scale(1.15); } 30% { transform: scale(1); } 45% { transform: scale(1.15); } }
        @keyframes dramaticFadeIn { to { opacity: 1; transform: rotateX(0) translateZ(0) translateY(0); } }
        @keyframes logoSmash { to { opacity: 1; transform: scale(1) translateZ(0); } }

        /* --- UI Components --- */
        .glass-panel { background: rgba(45, 31, 56, 0.75); backdrop-filter: blur(12px); border: 1px solid rgba(251, 113, 133, 0.2); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5); }
        .gold-text { color: var(--gold); }
        .shimmer-btn { position: relative; overflow: hidden; }
        .shimmer-btn::after {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.4), transparent);
            transform: rotate(45deg) translateX(-100%); animation: shimmer 3s infinite;
        }
        @keyframes shimmer { 0%, 20% { transform: rotate(45deg) translateX(-100%); } 80%, 100% { transform: rotate(45deg) translateX(100%); } }

        #tarot-app-container { opacity: 0; transition: opacity 2s ease; visibility: hidden; height: 100vh; overflow-y: auto; scroll-behavior: smooth; }
        .app-visible { opacity: 1 !important; visibility: visible !important; }

        .btn-gold { background: linear-gradient(135deg, #fda4af 0%, #fb7185 100%); color: #1e1525; font-weight: 600; }
        .btn-outline-gold { border: 1px solid var(--gold); color: var(--gold); transition: all 0.3s ease; }
        .btn-outline-gold:hover, .btn-outline-gold.active { background: rgba(251, 113, 133, 0.15); box-shadow: 0 0 10px rgba(251, 113, 133, 0.3); }

        .tarot-card-container { perspective: 1000px; cursor: pointer; }
        .tarot-card { width: 100%; padding-top: 170%; position: relative; transition: transform 0.6s; transform-style: preserve-3d; }
        .tarot-card.flipped { transform: rotateY(180deg); }
        .card-face { position: absolute; top: 0; left: 0; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 8px; border: 2px solid rgba(251, 113, 133, 0.5); display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: var(--dark-surface); }
        .card-back { background: linear-gradient(135deg, #2d1f38 0%, #1e1525 100%); background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(251, 113, 133, 0.05) 10px, rgba(251, 113, 133, 0.05) 20px); }
        .card-back::after { content: '✧'; font-size: 2rem; color: var(--gold); opacity: 0.5; }
        .card-front { transform: rotateY(180deg); background: #fdfbf7; }
        .real-tarot-img { width: 100%; height: 100%; object-fit: cover; }

        .fan-area { position: relative; width: 100%; height: clamp(200px, 35vh, 280px); margin-top: 1rem; margin-bottom: 3rem; user-select: none; }
        .fan-card { position: absolute; top: 0; left: calc(50% - 25px); width: clamp(45px, 11vw, 75px); height: clamp(75px, 17vw, 125px); transform-origin: center clamp(280px, 45vh, 420px); transform: rotate(var(--rot)); transition: 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); z-index: var(--idx); cursor: pointer; }
        .fan-card:hover { transform: rotate(var(--rot)) translateY(-30px) scale(1.1); z-index: 100 !important; border-color: var(--gold); box-shadow: 0 0 15px var(--gold); }
        
        .reading-content p { margin-bottom: 1.25rem; line-height: 1.8; letter-spacing: 0.04em; }
        .reading-content strong { color: #fb7185; font-weight: 600; }
        .action-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(251, 113, 133, 0.2); border-radius: 12px; padding: 1.5rem; transition: 0.3s; height: 100%; display: flex; align-items: center; justify-content: center; text-align: center; }
        .action-card:hover { border-color: var(--gold); transform: translateY(-3px); background: rgba(251, 113, 133, 0.05); }

        .archangel-box { background: linear-gradient(135deg, rgba(30, 21, 37, 0.95) 0%, rgba(10, 5, 15, 0.95) 100%); border: 1px solid rgba(251, 113, 133, 0.4); box-shadow: 0 0 25px rgba(251, 113, 133, 0.2); border-radius: 24px; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }
    </style>
</head>
